// ── Chart.js defaults
Chart.defaults.color='rgba(237,232,223,0.45)';
Chart.defaults.borderColor='rgba(237,232,223,0.07)';
Chart.defaults.font.family="'JetBrains Mono', monospace";
Chart.defaults.font.size=10;

const WARM='#c9a96e';
const CREAM='rgba(237,232,223,0.7)';
const DIM='rgba(237,232,223,0.22)';
const wf=a=>`rgba(201,169,110,${a})`;


// ── Modals
const built={};

function openModal(id){
  const el=document.getElementById(id); if(!el) return;
  document.body.style.overflow='hidden';
  el.classList.add('open');
  setTimeout(()=>buildChart(id),100);
}
function closeModal(el){
  el.classList.remove('open');
  document.body.style.overflow='';
}

document.querySelectorAll('[data-modal]').forEach(b=>b.addEventListener('click',()=>openModal(b.dataset.modal)));
document.querySelectorAll('[data-close]').forEach(b=>b.addEventListener('click',e=>{e.stopPropagation();closeModal(b.closest('.modal-overlay'));}));
document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)closeModal(o);}));
document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.modal-overlay.open').forEach(closeModal);});

// ── SVG helpers for hover previews ─────────────
  const W2=198,H2=84,PAD2=10;
  const df2=a=>`rgba(237,232,223,${a})`;
  const wf2=a=>`rgba(201,169,110,${a})`;
  const WARM_C='#c9a96e';

  function svgBar2(data,colors,labels){
    const max=Math.max(...data),pw=W2-PAD2*2,ph=H2-PAD2*2-12,bw=Math.floor(pw/data.length)-3;
    let s='';
    data.forEach((v,i)=>{
      const h=Math.round((v/max)*ph),x=PAD2+i*(bw+3);
      s+=`<rect x="${x}" y="${PAD2+ph-h}" width="${bw}" height="${h}" fill="${colors[i]}" rx="1"/>`;
      if(labels) s+=`<text x="${x+bw/2}" y="${H2-2}" text-anchor="middle" font-size="7" fill="${df2(.3)}" font-family="monospace">${labels[i]}</text>`;
    });
    return s;
  }
  function svgLine2(data,color){
    const max=Math.max(...data),min=Math.min(...data),pw=W2-PAD2*2,ph=H2-PAD2*2;
    const pts=data.map((v,i)=>`${PAD2+i*(pw/(data.length-1))},${PAD2+ph-((v-min)/(max-min||1))*ph}`).join(' ');
    return `<polyline points="${pts}" fill="none" stroke="${color}" stroke-width="1.8" stroke-linejoin="round"/>`;
  }

  const PREVIEWS={
    'modal-moneyball':{label:'OBP vs Vitorias — MLB',stat:'R²=0.36',statLabel:'OBP predicts wins',
      svg(){
        const pts=[[.310,83],[.320,75],[.330,85],[.340,85],[.345,102],[.350,91],[.360,102],[.370,90],[.375,97]];
        const xMin=.305,xMax=.380,yMin=48,yMax=120;
        const toX=x=>PAD2+(x-xMin)/(xMax-xMin)*(W2-PAD2*2);
        const toY=y=>(H2-PAD2)-(y-yMin)/(yMax-yMin)*(H2-PAD2*2);
        let s='';
        pts.forEach(([x,y])=>{s+=`<circle cx="${toX(x).toFixed(1)}" cy="${toY(y).toFixed(1)}" r="2.5" fill="rgba(100,140,255,0.7)"/>`;});
        const r1=[.308,468*.308-76],r2=[.375,468*.375-76];
        s+=`<line x1="${toX(r1[0]).toFixed(1)}" y1="${toY(r1[1]).toFixed(1)}" x2="${toX(r2[0]).toFixed(1)}" y2="${toY(r2[1]).toFixed(1)}" stroke="rgba(220,80,60,0.9)" stroke-width="1.5"/>`;
        s+=`<circle cx="${toX(.345).toFixed(1)}" cy="${toY(102).toFixed(1)}" r="4" fill="${WARM_C}" stroke="#0c0b09" stroke-width="1"/>`;
        return s;
      }
    },
    'modal-pharma':{label:'Medicamentos em falta',stat:'139',statLabel:'UBS Aparecidinha (50,5%)',
      svg(){
        const data=[139,138,135,131,127],pcts=['50,5%','50%','49%','47%','46%'],labels=['Aparec.','Lopes','V.Ang.','Jd.Rod.','V.Barc.'];
        const max=145,pw=W2-PAD2*2-28,bh=10,gap=4;
        let s='';
        data.forEach((v,i)=>{
          const w=(v/max)*pw,y=PAD2+i*(bh+gap),alpha=0.95-i*0.12;
          s+=`<rect x="${PAD2}" y="${y}" width="${w.toFixed(1)}" height="${bh}" fill="${wf2(alpha)}" rx="1"/>`;
          s+=`<text x="${PAD2+w+3}" y="${y+bh-1}" font-size="7" fill="${wf2(.7)}" font-family="monospace">${pcts[i]}</text>`;
          s+=`<text x="${PAD2-2}" y="${y+bh-1}" text-anchor="end" font-size="6.5" fill="${df2(.3)}" font-family="monospace">${labels[i]}</text>`;
        });
        return s;
      }
    },
    'modal-9mm':{label:'Pistolas apreendidas — PF',stat:'21',statLabel:'de 36 sao 9mm (58%)',
      svg(){return svgBar2([21,11,4,3],[wf2(.95),wf2(.6),wf2(.4),wf2(.25)],['9mm','.40','.45','Carab.']);}
    },
    'modal-favelas':{label:'Favelas de Sorocaba',stat:'12k+',statLabel:'moradores sem servicos proximos',
      svg(){
        const pts=[[40,30],[70,45],[55,60],[90,35],[110,50],[80,65],[130,40],[100,70],[60,80],[120,30]];
        let s='';
        pts.forEach(([x,y],i)=>{s+=`<circle cx="${x}" cy="${y}" r="${3+i%3}" fill="${wf2(.4+i*.05)}" opacity=".8"/>`;});
        s+=`<text x="${W2/2}" y="${H2-2}" text-anchor="middle" font-size="7" fill="${df2(.2)}" font-family="monospace">mapa de favelas</text>`;
        return s;
      }
    },
    'modal-dv':{label:'BOs x distancia da DDM',stat:'18km',statLabel:'Vitoria Regia — mais longe',
      svg(){
        const bairros=[['Pq. S.Bento',97,13.5,.9],['Vila Barao',68,4.9,.6],['Pq.Vit.Regia',60,18.0,.4]];
        const xMin=0,xMax=22,yMin=0,yMax=110;
        const toX=x=>PAD2+(x-xMin)/(xMax-xMin)*(W2-PAD2*2);
        const toY=y=>(H2-PAD2-10)-(y-yMin)/(yMax-yMin)*(H2-PAD2*2-10);
        let s='';
        s+=`<line x1="${PAD2}" y1="${H2-PAD2-10}" x2="${W2-PAD2}" y2="${H2-PAD2-10}" stroke="${df2(.08)}" stroke-width=".5"/>`;
        s+=`<text x="${W2/2}" y="${H2-1}" text-anchor="middle" font-size="6.5" fill="${df2(.2)}" font-family="monospace">distancia da DDM (km)</text>`;
        bairros.forEach(([nome,bos,dist,alpha])=>{
          const cx=toX(dist),cy=toY(bos),r=Math.round(4+bos/16);
          s+=`<circle cx="${cx.toFixed(1)}" cy="${cy.toFixed(1)}" r="${r}" fill="${wf2(alpha)}" stroke="${wf2(alpha+.2)}" stroke-width="1"/>`;
          s+=`<text x="${cx.toFixed(1)}" y="${(cy-r-2).toFixed(1)}" text-anchor="middle" font-size="6" fill="${df2(.45)}" font-family="monospace">${nome}</text>`;
          s+=`<text x="${cx.toFixed(1)}" y="${(cy+3).toFixed(1)}" text-anchor="middle" font-size="7" fill="${df2(.8)}" font-family="monospace" font-weight="bold">${bos}</text>`;
        });
        return s;
      }
    },
    'modal-wanted':{label:'Mandados pendentes — CNJ',stat:'53',statLabel:'mandados ha 10+ anos em Sorocaba',
      svg(){return svgBar2([7,31,4,8,1,1,1],[wf2(.45),wf2(.9),wf2(.5),wf2(.7),wf2(.32),wf2(.28),wf2(.24)],['10','11','12','13','14','15','16']);}
    },
    'modal-music':{label:'All We Know Is Falling — Paramore',stat:'0.21',statLabel:'valencia minima — Franklin',
      svg(){
        const valence=[0.37,0.46,0.32,0.56,0.21,0.54,0.36,0.53,0.66,0.42];
        const energy=[0.91,0.93,0.91,0.94,0.69,0.85,0.80,0.88,0.89,0.93];
        const n=valence.length,pw=W2-PAD2*2,ph=H2-PAD2*2-8;
        const toX=i=>PAD2+i*(pw/(n-1));
        const toY=v=>(H2-PAD2-8)-(v*ph);
        let s='';
        s+=`<polyline points="${energy.map((v,i)=>`${toX(i).toFixed(1)},${toY(v).toFixed(1)}`).join(' ')}" fill="none" stroke="rgba(80,190,160,0.45)" stroke-width="1.5" stroke-linejoin="round"/>`;
        s+=`<polyline points="${valence.map((v,i)=>`${toX(i).toFixed(1)},${toY(v).toFixed(1)}`).join(' ')}" fill="none" stroke="${WARM_C}" stroke-width="1.8" stroke-linejoin="round"/>`;
        s+=`<circle cx="${toX(4).toFixed(1)}" cy="${toY(0.21).toFixed(1)}" r="3.5" fill="${WARM_C}"/>`;
        s+=`<text x="${toX(4).toFixed(1)}" y="${(toY(0.21)-5).toFixed(1)}" text-anchor="middle" font-size="6.5" fill="${WARM_C}" font-family="monospace">Franklin</text>`;
        return s;
      }
    }
  };

  // ── Hover Preview Logic ─────────────────────────
  const previewCard=document.getElementById('previewCard');
  document.querySelectorAll('[data-modal]').forEach(btn=>{
    btn.addEventListener('mouseenter',()=>{
      const id=btn.dataset.modal,p=PREVIEWS[id]; if(!p) return;
      document.getElementById('previewLabel').textContent=p.label;
      document.getElementById('previewSvg').innerHTML=p.svg();
      document.getElementById('previewStat').textContent=p.stat;
      document.getElementById('previewStatLabel').textContent=p.statLabel;
      previewCard.classList.add('visible');
    });
    btn.addEventListener('mouseleave',()=>previewCard.classList.remove('visible'));
  });
  document.addEventListener('mousemove',e=>{
    const x=e.clientX+20,y=e.clientY+20;
    previewCard.style.left=(x+240>window.innerWidth?e.clientX-240:x)+'px';
    previewCard.style.top=(y+160>window.innerHeight?e.clientY-160:y)+'px';
  });

// ── Chart builders
function buildChart(id) {
  if (built[id]) return;
  built[id] = true;

  if (id === 'modal-moneyball') {
    const teamData=[
      {x:.310,y:83},{x:.310,y:76},{x:.310,y:65},{x:.312,y:90},{x:.314,y:63},
      {x:.320,y:75},{x:.320,y:76},{x:.321,y:68},{x:.322,y:68},{x:.323,y:67},
      {x:.323,y:71},{x:.325,y:73},{x:.326,y:79},{x:.327,y:66},{x:.328,y:73},
      {x:.329,y:83},{x:.330,y:85},{x:.331,y:69},{x:.332,y:81},{x:.333,y:72},
      {x:.334,y:78},{x:.335,y:80},{x:.336,y:82},{x:.337,y:92},{x:.338,y:79},
      {x:.339,y:88},{x:.340,y:85},{x:.341,y:91},{x:.342,y:87},{x:.343,y:86},
      {x:.344,y:93},{x:.345,y:88},{x:.346,y:95},{x:.347,y:90},{x:.348,y:94},
      {x:.349,y:96},{x:.350,y:91},{x:.351,y:93},{x:.352,y:98},{x:.353,y:95},
      {x:.354,y:97},{x:.355,y:100},{x:.356,y:95},{x:.357,y:99},{x:.358,y:97},
      {x:.359,y:96},{x:.360,y:102},{x:.361,y:103},{x:.362,y:98},{x:.363,y:101},
      {x:.364,y:99},{x:.365,y:104},{x:.366,y:102},{x:.367,y:107},{x:.368,y:99},
      {x:.369,y:97},{x:.370,y:90},{x:.373,y:97}
    ];
    new Chart(document.getElementById('chart-moneyball'), {
      type:'scatter',
      data:{datasets:[
        {label:'Equipes MLB',data:teamData,backgroundColor:'rgba(100,140,255,0.7)',pointRadius:4,pointHoverRadius:6},
        {label:'Regressao linear',data:[{x:.308,y:468*.308-76},{x:.375,y:468*.375-76}],type:'line',borderColor:'rgba(220,80,60,0.9)',backgroundColor:'transparent',pointRadius:0,borderWidth:2,tension:0,showLine:true},
        {label:'Oakland Athletics 2001',data:[{x:.345,y:102}],backgroundColor:WARM,pointRadius:8,pointHoverRadius:10,pointStyle:'star'}
      ]},
      options:{
        responsive:true,
        plugins:{legend:{labels:{color:CREAM,padding:14}},tooltip:{callbacks:{label:c=>`${c.dataset.label}: OBP ${c.parsed.x.toFixed(3)}, ${c.parsed.y} vitorias`}}},
        scales:{
          x:{title:{display:true,text:'On-Base Percentage (OBP)',color:DIM},min:.305,max:.38,grid:{color:'rgba(237,232,223,0.05)'},ticks:{color:DIM,callback:v=>v.toFixed(3)}},
          y:{title:{display:true,text:'Numero de Vitorias',color:DIM},min:48,max:120,grid:{color:'rgba(237,232,223,0.05)'},ticks:{color:DIM}}
        }
      }
    });
  }

  // pharma, 9mm, favelas: iframes — sem Chart.js

  if (id === 'modal-dv') {
    new Chart(document.getElementById('chart-dv'), {
      type:'bubble',
      data:{datasets:[
        {label:'Parque Sao Bento',data:[{x:13.5,y:97,r:18}],backgroundColor:wf(.85),borderColor:WARM,borderWidth:1.5},
        {label:'Vila Barao',data:[{x:4.9,y:68,r:14}],backgroundColor:wf(.55),borderColor:wf(.8),borderWidth:1.5},
        {label:'Parque Vitoria Regia',data:[{x:18.0,y:60,r:12}],backgroundColor:wf(.35),borderColor:wf(.6),borderWidth:1.5}
      ]},
      options:{
        responsive:true,
        plugins:{legend:{labels:{color:CREAM,font:{size:11},padding:16}},tooltip:{callbacks:{label:c=>`${c.dataset.label}: ${c.parsed.y} BOs · ${c.parsed.x}km da DDM`}}},
        scales:{
          x:{title:{display:true,text:'Distancia da DDM (km)',color:DIM},min:0,max:22,grid:{color:'rgba(237,232,223,0.05)'},ticks:{color:DIM,callback:v=>v+'km'}},
          y:{title:{display:true,text:'Boletins de Ocorrencia (2023)',color:DIM},min:0,max:120,grid:{color:'rgba(237,232,223,0.05)'},ticks:{color:DIM}}
        }
      }
    });
  }

  if (id === 'modal-wanted') {
    new Chart(document.getElementById('chart-wanted'), {
      type:'bar',
      data:{
        labels:['10 anos','11 anos','12 anos','13 anos','14 anos','15 anos','16 anos'],
        datasets:[{label:'Mandados pendentes',data:[7,31,4,8,1,1,1],
          backgroundColor:[wf(.45),wf(.9),wf(.5),wf(.7),wf(.35),wf(.3),wf(.25)],borderWidth:0,borderRadius:3}]
      },
      options:{
        responsive:true,
        plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`${c.parsed.y} mandado${c.parsed.y>1?'s':''} pendente${c.parsed.y>1?'s':''}`}}},
        scales:{
          y:{grid:{color:'rgba(237,232,223,0.05)'},ticks:{color:DIM},title:{display:true,text:'No de mandados',color:DIM}},
          x:{grid:{display:false},ticks:{color:CREAM},title:{display:true,text:'Tempo pendente',color:DIM}}
        }
      }
    });
  }

  if (id === 'modal-music') {
    const songs=['All We Know','Brighter','Conspiracy','Emergency','Franklin','Here We Go Again','My Heart','Never Let This Go','Pressure','Whoa'];
    const attrs=['danceability','energy','valence'];
    const data={danceability:[0.50,0.50,0.49,0.42,0.49,0.51,0.44,0.52,0.51,0.33],energy:[0.91,0.93,0.91,0.94,0.69,0.85,0.80,0.88,0.89,0.93],valence:[0.37,0.46,0.32,0.56,0.21,0.54,0.36,0.53,0.66,0.42]};
    const stops=[[0,[8,7,26]],[0.25,[48,35,95]],[0.5,[50,130,140]],[0.75,[70,185,165]],[1,[202,237,217]]];
    function mako(v){let i=0;while(i<stops.length-2&&v>stops[i+1][0])i++;const [t0,c0]=stops[i],[t1,c1]=stops[i+1],t=(v-t0)/(t1-t0);return [0,1,2].map(j=>Math.round(c0[j]+(c1[j]-c0[j])*t));}
    function tc(r,g,b){return(0.299*r+0.587*g+0.114*b)>140?'#1a1a2e':'#ede8df';}
    const wrap=document.getElementById('chart-music');
    const colW=72,rowH=40,labelW=100;
    let html=`<div style="font-family:'JetBrains Mono',monospace;font-size:9px;">`;
    html+=`<div style="display:flex;margin-left:${labelW}px;margin-bottom:4px;">`;
    songs.forEach(s=>{html+=`<div style="width:${colW}px;flex-shrink:0;text-align:center;color:rgba(237,232,223,0.5);font-size:8px;padding:0 2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${s}">${s}</div>`;});
    html+=`</div>`;
    attrs.forEach(attr=>{
      html+=`<div style="display:flex;align-items:center;margin-bottom:3px;">`;
      html+=`<div style="width:${labelW}px;flex-shrink:0;color:rgba(237,232,223,0.6);font-size:9px;letter-spacing:.1em;padding-right:12px;text-align:right;">${attr}</div>`;
      data[attr].forEach(v=>{const [r,g,b]=mako(v);html+=`<div style="width:${colW}px;height:${rowH}px;flex-shrink:0;background:rgb(${r},${g},${b});display:flex;align-items:center;justify-content:center;font-size:10px;color:${tc(r,g,b)};font-weight:500;margin:0 1px;border-radius:2px;">${v.toFixed(2)}</div>`;});
      html+=`</div>`;
    });
    html+=`<div style="display:flex;align-items:center;gap:8px;margin-top:16px;margin-left:${labelW}px;"><span style="color:rgba(237,232,223,0.3);font-size:8px;">0.0</span><div style="flex:1;max-width:160px;height:8px;border-radius:2px;background:linear-gradient(to right,rgb(8,7,26),rgb(48,35,95),rgb(50,130,140),rgb(70,185,165),rgb(202,237,217));"></div><span style="color:rgba(237,232,223,0.3);font-size:8px;">1.0</span></div>`;
    html+=`</div>`;
    wrap.innerHTML=html;
  }
}
</script>
</body>
</html>
