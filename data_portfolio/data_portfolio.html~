<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Matheus Arruda — Data Storytelling</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg: #0c0b09;
    --cream: #ede8df;
    --warm: #c9a96e;
    --muted: rgba(237,232,223,0.35);
    --faint: rgba(237,232,223,0.08);
    --mono: 'JetBrains Mono', monospace;
    --display: 'Cormorant', serif;
    --sans: 'Syne', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--cream);
    font-family: var(--sans);
    cursor: none;
    overflow-x: hidden;
  }

  /* ── CUSTOM CURSOR ───────────────────────────── */
  .cursor {
    position: fixed;
    width: 8px; height: 8px;
    background: var(--warm);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: width .2s, height .2s, background .2s;
  }
  .cursor-ring {
    position: fixed;
    width: 36px; height: 36px;
    border: 1px solid rgba(201,169,110,0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition: width .35s cubic-bezier(.16,1,.3,1), height .35s cubic-bezier(.16,1,.3,1), border-color .2s;
  }
  body:has(.project-row:hover) .cursor { width: 56px; height: 56px; background: var(--warm); opacity: .15; }
  body:has(.project-row:hover) .cursor-ring { width: 70px; height: 70px; border-color: var(--warm); }

  /* ── NAV ─────────────────────────────────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 48px;
    mix-blend-mode: normal;
  }
  nav::after {
    content: '';
    position: absolute; bottom: 0; left: 48px; right: 48px;
    height: 1px;
    background: var(--faint);
  }
  .nav-logo {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: .7;
    text-decoration: none;
  }
  .nav-links {
    display: flex; gap: 36px;
    list-style: none;
  }
  .nav-links a {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: .5;
    text-decoration: none;
    transition: opacity .2s;
  }
  .nav-links a:hover { opacity: 1; color: var(--warm); }

  /* ── HERO ────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 48px 60px;
    position: relative;
    overflow: hidden;
  }
  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: -0.05em;
    transform: translateY(-50%);
    font-family: var(--display);
    font-size: clamp(120px, 22vw, 280px);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px rgba(237,232,223,0.04);
    pointer-events: none;
    white-space: nowrap;
    line-height: 1;
    user-select: none;
  }
  .hero-tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--warm);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp .8s .2s cubic-bezier(.16,1,.3,1) forwards;
  }
  .hero-title {
    font-family: var(--display);
    font-size: clamp(62px, 9.5vw, 130px);
    font-weight: 300;
    line-height: .95;
    letter-spacing: -.02em;
    margin-bottom: 48px;
    opacity: 0;
    animation: fadeUp .9s .35s cubic-bezier(.16,1,.3,1) forwards;
  }
  .hero-title em {
    font-style: italic;
    color: var(--warm);
  }
  .hero-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-top: 1px solid var(--faint);
    padding-top: 32px;
    opacity: 0;
    animation: fadeUp .8s .55s cubic-bezier(.16,1,.3,1) forwards;
  }
  .hero-role {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: .5;
    line-height: 1.8;
  }
  .hero-scroll {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: .4;
  }
  .hero-scroll-line {
    width: 40px;
    height: 1px;
    background: var(--cream);
    opacity: .4;
    animation: expandLine 1.2s 1s cubic-bezier(.16,1,.3,1) both;
    transform-origin: left;
  }

  /* ── SECTION WRAPPER ─────────────────────────── */
  section { padding: 0 48px; }
  .section-header {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 80px 0 40px;
    border-top: 1px solid var(--faint);
  }
  .section-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--warm);
  }
  .section-line {
    flex: 1;
    height: 1px;
    background: var(--faint);
  }
  .section-count {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: .1em;
  }

  /* ── PROJECTS ────────────────────────────────── */
  #projects { padding-bottom: 0; }
  .project-row {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: start;
    padding: 28px 0;
    border-bottom: 1px solid var(--faint);
    cursor: none;
    position: relative;
    transition: background .25s;
    text-decoration: none;
    color: inherit;
    background: none !important;
    background-color: transparent !important;
    border-left: none;
    border-right: none;
    border-top: none;
    width: 100%;
    text-align: left;
    font-family: inherit;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
    overflow: hidden; /* Garante que o ::before não escape */
  }
  
  .project-row::before {
    content: '';
    position: absolute;
    left: 0; 
    right: 0; 
    top: 0; bottom: 0;
    background: var(--cream);
    opacity: 0;
    transition: opacity .3s;
    z-index: 0;  /* Adicione isso para garantir que fique atrás do texto */
  }
  .project-row:hover::before { opacity: 0.03; }

  .project-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    padding-top: 6px;
    letter-spacing: .05em;
  }
  .project-title {
    font-family: var(--display);
    font-size: clamp(28px, 3.5vw, 46px);
    font-weight: 400;
    line-height: 1;
    margin-bottom: 10px;
    transition: color .25s;
    letter-spacing: -.01em;
  }
  .project-row:hover .project-title { color: var(--warm); }
  .project-desc {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    max-width: 520px;
    font-weight: 400;
    max-height: 0;
    overflow: hidden;
    transition: max-height .4s cubic-bezier(.16,1,.3,1), opacity .3s;
    opacity: 0;
  }
  .project-row:hover .project-desc { max-height: 80px; opacity: 1; }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
    max-height: 0;
    overflow: hidden;
    transition: max-height .4s .05s cubic-bezier(.16,1,.3,1), opacity .3s .05s;
    opacity: 0;
  }
  .project-row:hover .project-tags { max-height: 40px; opacity: 1; }
  .tag {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: .4;
    border: 1px solid var(--faint);
    padding: 4px 10px;
    border-radius: 2px;
  }
  .project-meta {
    text-align: right;
    padding-top: 6px;
  }
  .project-date {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .12em;
    color: var(--muted);
    display: block;
    margin-bottom: 6px;
  }
  .project-status {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--warm);
    opacity: .7;
    display: block;
  }

  /* MODAL */
  .modal-overlay {
    position:fixed; inset:0; z-index:1000;
    background:rgba(12,11,9,0.9); backdrop-filter:blur(14px);
    display:flex; align-items:center; justify-content:center;
    opacity:0; pointer-events:none; transition:opacity .4s cubic-bezier(.16,1,.3,1);
    cursor:none; padding:24px;
  }
  .modal-overlay.open { opacity:1; pointer-events:all; }
  .modal {
    background:#131210; border:1px solid rgba(237,232,223,0.1);
    width:min(860px,94vw); max-height:90vh; overflow-y:auto;
    position:relative; transform:translateY(32px) scale(.97);
    transition:transform .45s cubic-bezier(.16,1,.3,1); scrollbar-width:none;
  }
  .modal::-webkit-scrollbar { display:none; }
  .modal-overlay.open .modal { transform:translateY(0) scale(1); }
  .modal-header { padding:40px 48px 24px; border-bottom:1px solid rgba(237,232,223,0.07); display:flex; justify-content:space-between; align-items:flex-start; gap:24px; }
  .modal-title { font-family:var(--display); font-size:clamp(26px,4vw,44px); font-weight:300; line-height:1; letter-spacing:-.02em; }
  .modal-close { background:none; border:none; cursor:none; font-family:var(--mono); font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--muted); padding:6px 0 6px 16px; transition:color .2s; flex-shrink:0; margin-top:8px; }
  .modal-close:hover { color:var(--warm); }
  .modal-body { padding:32px 48px 48px; }
  .modal-desc { font-family:var(--sans); font-size:14px; color:var(--muted); line-height:1.8; max-width:580px; margin-bottom:32px; }
  .modal-insight { font-family:var(--display); font-size:clamp(17px,2.2vw,24px); font-weight:300; line-height:1.3; color:var(--cream); font-style:italic; border-left:2px solid var(--warm); padding-left:20px; margin-bottom:32px; }
  .modal-chart-wrap { position:relative; width:100%; background:rgba(237,232,223,0.02); border:1px solid rgba(237,232,223,0.06); padding:36px 20px 20px; margin-bottom:28px; }
  .modal-chart-label { font-family:var(--mono); font-size:9px; letter-spacing:.22em; text-transform:uppercase; color:var(--warm); opacity:.7; position:absolute; top:13px; left:20px; }
  .modal-chart-wrap canvas { max-height:300px; }
  .modal-tags { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:28px; }
  .modal-link { display:inline-flex; align-items:center; gap:10px; font-family:var(--mono); font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--cream); opacity:.5; text-decoration:none; transition:opacity .2s,color .2s; border-bottom:1px solid rgba(237,232,223,0.15); padding-bottom:4px; }
  .modal-link:hover { opacity:1; color:var(--warm); border-color:var(--warm); }
  .modal-link::after { content:'↗'; }

  /* ── ABOUT ───────────────────────────────────── */
  #about {
    padding-bottom: 120px;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding-top: 20px;
  }
  .about-statement {
    font-family: var(--display);
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -.01em;
    color: var(--cream);
  }
  .about-statement em {
    font-style: italic;
    color: var(--warm);
  }
  .about-right {
    display: flex;
    flex-direction: column;
    gap: 48px;
    padding-top: 8px;
  }
  .about-block-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--warm);
    margin-bottom: 16px;
    display: block;
  }
  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .skill-list li {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--cream);
    opacity: .7;
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 400;
  }
  .skill-list li::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--warm);
    opacity: .5;
    flex-shrink: 0;
  }
  .edu-item {
    padding-bottom: 20px;
    border-bottom: 1px solid var(--faint);
    margin-bottom: 20px;
  }
  .edu-item:last-child { border-bottom: none; margin-bottom: 0; }
  .edu-degree {
    font-family: var(--display);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 6px;
  }
  .edu-school {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--muted);
  }
  .edu-year {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--warm);
    opacity: .7;
    margin-top: 4px;
    display: block;
  }

  /* ── EXPERIENCE ──────────────────────────────── */
  #experience { padding-bottom: 120px; }
  .exp-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    padding: 40px 0;
    border-bottom: 1px solid var(--faint);
  }
  .exp-period {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .15em;
    color: var(--warm);
    opacity: .8;
    display: block;
    margin-bottom: 8px;
  }
  .exp-company {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .08em;
    color: var(--muted);
  }
  .exp-role {
    font-family: var(--display);
    font-size: clamp(22px, 2.5vw, 34px);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 16px;
    letter-spacing: -.01em;
  }
  .exp-body {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--cream);
    opacity: .55;
    line-height: 1.8;
    max-width: 560px;
    font-weight: 400;
  }

  /* ── CONTACT ─────────────────────────────────── */
  #contact {
    padding-bottom: 80px;
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .contact-inner { max-width: 100%; }
  .contact-headline {
    font-family: var(--display);
    font-size: clamp(52px, 8vw, 110px);
    font-weight: 300;
    line-height: .95;
    letter-spacing: -.03em;
    margin: 40px 0 60px;
  }
  .contact-headline em { font-style: italic; color: var(--warm); }
  .contact-links {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }
  .contact-link {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: .5;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: opacity .2s, color .2s;
  }
  .contact-link:hover { opacity: 1; color: var(--warm); }
  .contact-link::after {
    content: '↗';
    font-size: 14px;
    transition: transform .2s;
  }
  .contact-link:hover::after { transform: translate(2px,-2px); }

  /* ── FOOTER ──────────────────────────────────── */
  footer {
    border-top: 1px solid var(--faint);
    padding: 28px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  footer span {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .15em;
    color: var(--cream);
    opacity: .25;
    text-transform: uppercase;
  }

  /* ── ANIMATIONS ──────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes expandLine {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
  
  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity .8s cubic-bezier(.16,1,.3,1), transform .8s cubic-bezier(.16,1,.3,1);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── HOVER PREVIEW CARD ──────────────────────── */
  .preview-card {
    position: fixed;
    width: 220px;
    background: #1a1814;
    border: 1px solid rgba(201,169,110,0.2);
    padding: 16px;
    pointer-events: none;
    z-index: 500;
    opacity: 0;
    transform: translateY(8px) scale(.97);
    transition: opacity .22s cubic-bezier(.16,1,.3,1), transform .22s cubic-bezier(.16,1,.3,1);
  }
  .preview-card.visible { opacity: 1; transform: translateY(0) scale(1); }
  .preview-label {
    font-family: var(--mono);
    font-size: 8px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--warm);
    opacity: .7;
    margin-bottom: 10px;
    display: block;
  }
  .preview-svg-wrap { width: 198px; height: 84px; overflow: hidden; }
  .preview-svg-wrap svg { width: 198px; height: 84px; }
  .preview-stat {
    font-family: var(--display);
    font-size: 28px;
    font-weight: 300;
    color: var(--warm);
    line-height: 1;
    margin-top: 10px;
  }
  .preview-stat-label {
    font-family: var(--mono);
    font-size: 8px;
    letter-spacing: .12em;
    color: rgba(237,232,223,0.35);
    margin-top: 4px;
    display: block;
  }

  /* ── RESPONSIVE ──────────────────────────────── */
  @media (max-width: 768px) {
    nav { padding: 24px 24px; }
    nav::after { left: 24px; right: 24px; }
    .nav-links { gap: 20px; }
    .hero { padding: 0 24px 48px; }
    section { padding: 0 24px; }
    footer { padding: 24px; flex-direction: column; gap: 12px; text-align: center; }
    .about-grid { grid-template-columns: 1fr; gap: 48px; }
    .exp-item { grid-template-columns: 1fr; gap: 12px; }
    .project-row { grid-template-columns: 50px 1fr auto; }
    .contact-links { gap: 24px; }
  }
</style>
</head>
<body>

<!-- Cursor -->
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- Hover Preview Card -->
<div class="preview-card" id="previewCard">
  <span class="preview-label" id="previewLabel"></span>
  <div class="preview-svg-wrap">
    <svg id="previewSvg" viewBox="0 0 198 84" xmlns="http://www.w3.org/2000/svg"></svg>
  </div>
  <div class="preview-stat" id="previewStat"></div>
  <span class="preview-stat-label" id="previewStatLabel"></span>
</div>

<!-- Nav -->
<nav>
  <a href="#" class="nav-logo">Matheus Arruda</a>
  <ul class="nav-links">
    <li><a href="#projects">Work</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- Hero -->
<div class="hero">
  <div class="hero-bg-text"></div>
  <p class="hero-tag">Data Analyst &amp; Storyteller — São Paulo, BR</p>
  <h1 class="hero-title">
    Numbers that<br>
    <em>tell stories</em>
  </h1>
  <div class="hero-bottom">
    <p class="hero-role">
      Data Analyst @ g1 — Globo News Portal<br>
      Python & SQL Specialist · Automation & ETL · Machine Learning · DataViz · Power BI
    </p>
    <div class="hero-scroll">
      <div class="hero-scroll-line"></div>
      Scroll
    </div>
  </div>
</div>

<!-- Projects -->
<section id="projects">
  <div class="section-header reveal">
    <span class="section-label">Selected Work</span>
    <div class="section-line"></div>
    <span class="section-count">08 Projects</span>
  </div>

  <a class="project-row reveal" href="https://github.com/mtharruda/Auditorium/blob/main/README.md" target="_blank">
    <span class="project-num">01</span>
    <div class="project-main">
      <h2 class="project-title">Auditorium: AI-Driven Predictive Analytics & NLP</h2>
      <p class="project-desc">Developed a machine learning application to predict audience engagement and optimize content strategy.</p>
      <div class="project-tags">
        <span class="tag">Python</span>
        <span class="tag">Scikit-Learn</span>
        <span class="tag">FuzzyWuzzy</span>
        <span class="tag">Google Gemini</span>
      </div>
    </div>
    <div class="project-meta">
      <span class="project-date">Jan 2025</span>
      <span class="project-status">Published</span>
    </div>
  </a>
  
  <!-- 02–08 → modais -->
  <button class="project-row reveal" data-modal="modal-moneyball">
